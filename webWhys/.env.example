# webWhys Environment Configuration
# Copy this file to .env and fill in your values.

# LLM model to use (required)
# Supports any model via litellm: gpt-4o-mini, gpt-4o, claude-3-5-sonnet-20241022, etc.
LLM_MODEL=gpt-4o-mini

# OpenAI API key (required for OpenAI models)
OPENAI_API_KEY=sk-...

# Anthropic API key (required for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Logging level: WARNING (default — silent), INFO (basic), DEBUG (verbose)
# LOG_LEVEL=WARNING
